// OPR 물류 실적 대시보드 — Prisma 전체 데이터 모델
// ─────────────────────────────────────────────────────────────────────────────
// 근거: 04_시스템_설계/아키텍처_대시보드MVP.md §1 (데이터 모델 8테이블)
//        §1-3 Prisma schema 초안 그대로 + Auth.js 표준 모델.
//   8 코어: Snapshot · RawRow · FactKanban · DimClass · Annotation · User
//           · TabPermission · IngestLog
//   + Auth.js: Account · Session · VerificationToken (PrismaAdapter)
//   + 매장②·상품③ fast-follow 자리: FactStore · FactProductCum (스키마만)
//
// 연결 URL 은 schema 가 아닌 prisma.config.ts(DATABASE_URL_UNPOOLED).
// 런타임은 driver adapter(@prisma/adapter-neon) — src/lib/prisma.ts.
// ⚠️ Neon 미구성 → 마이그레이션은 --create-only 로 파일만 생성(적용 X).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── enums ──────────────────────────────────────────────────────────────────
enum Role {
  ADMIN
  STAFF
  VIEWER
}

enum PeriodType {
  MONTH // 당월
  CUMULATIVE // 누적
}

// 스냅샷 데이터셋 종류 — 아이템(①)/매장(②)/상품(③) 분리. CURRENT 조회 격리키.
enum FileType {
  ITEM // 아이템(시즌-아이템 엔진)
  STORE // 매장(점포 SCM)
  PRODUCT // 상품(③ fast-follow)
}

enum SnapStatus {
  PROCESSING
  CURRENT
  SUPERSEDED
  FAILED
}

enum SheetType {
  매출상세
  점재고
  물류재고
  센터입출고
  기초재고_센터
  기초재고_지점
  물류비예측
  분류
}

enum PermLevel {
  VIEW
  INPUT
  MANAGE
}

enum AnnoKind {
  REMARK // 비고
  ACTION // 조치
  TARGET // 목표
  PRIOR_YEAR // 전년
  LOGI_COST // 물류비(수기)
}

enum IngestPhase {
  UPLOAD
  VALIDATE
  PARSE
  STAGE
  TRANSFORM
  PUBLISH
}

enum IngestResult {
  OK
  WARN
  ERROR
}

// ── 업로드 / 스냅샷 (시계열 이력 헤드) ─────────────────────────────────────────
model Snapshot {
  id           String       @id @default(cuid())
  periodType   PeriodType
  /// 데이터셋 종류(아이템/매장/상품). 기존 행 = ITEM(기본). CURRENT 조회 격리.
  fileType     FileType     @default(ITEM)
  periodStart  DateTime     @db.Date
  periodEnd    DateTime     @db.Date
  status       SnapStatus   @default(PROCESSING)
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  uploadedAt   DateTime     @default(now())
  rowCount     Int          @default(0)
  /// 원본 .xlsx Blob URL(감사·재처리용). Neon 구성 후 @vercel/blob.
  blobUrl      String?
  raws         RawRow[]
  facts        FactKanban[]
  storeFacts   FactStore[]
  productFacts FactProductCum[]
  logs         IngestLog[]

  @@index([periodType, periodEnd])
  @@index([status])
  @@map("snapshots")
}

// ── RAW 통합 스테이징 (sheet_type 구분, JSONB) ────────────────────────────────
model RawRow {
  id         String    @id @default(cuid())
  snapshotId String
  snapshot   Snapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  sheetType  SheetType
  rowIndex   Int
  /// SKU 조인키(A열 = 계절연도-MC자재그룹), 정규화. 마스터/물류비예측은 "".
  skuKey     String    @default("")
  /// 원행 그대로(컬럼문자→값 map)
  data       Json

  @@index([snapshotId, sheetType])
  @@index([snapshotId, sheetType, skuKey])
  @@map("raw_rows")
}

// ── 엔진 집계 팩트 ① 물류 (snapshot × 4키, 19지표) ───────────────────────────
model FactKanban {
  id         String   @id @default(cuid())
  snapshotId String
  snapshot   Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  gender     String // 여성/남성/아동
  newcarry   String // 신상/이월
  season     String // 봄/여름/가을/겨울/공통
  item       String // 상의류…아동복
  skuKey     String? // L5 옵션(없으면 4키 사전집계 행)

  // 19 기초지표 (아키텍처 §1-3 / 수식맵 §2-2) — Decimal, NULL→0 적재
  mSales    Decimal @db.Decimal(18, 2) // J 추정매출
  /// N 실매출액(원본) — SKU 상세(GET /api/agg/sku) 응답 계약 보존용. 추정매출(mSales=J)과 별개.
  mSalesNet Decimal @default(0) @db.Decimal(18, 2)
  mLogiCost Decimal @db.Decimal(18, 2) // K 물류비
  mRent     Decimal @db.Decimal(18, 2) // BG 임차료(공간비)
  mLabor    Decimal @db.Decimal(18, 2) // BN 인건비
  mFreight  Decimal @db.Decimal(18, 2) // BT 운반비
  mPack     Decimal @db.Decimal(18, 2) // BV 포장비
  mCtrQty   Decimal @db.Decimal(18, 2) // Y 센터재고량
  mCtrAmt   Decimal @db.Decimal(18, 2) // Z 센터재고액
  mStoQty   Decimal @db.Decimal(18, 2) // AE 점포재고량
  mStoAmt   Decimal @db.Decimal(18, 2) // AF 점포재고액
  mOpenAll  Decimal @db.Decimal(18, 2) // AK 기초전체
  mOpenCtr  Decimal @db.Decimal(18, 2) // AL 기초물류
  mOpenSto  Decimal @db.Decimal(18, 2) // AM 기초지점
  mDailyOut Decimal @db.Decimal(18, 2) // P 일평균소진액
  mInQty    Decimal @db.Decimal(18, 2) // AT 입고
  mOutQty   Decimal @db.Decimal(18, 2) // AZ 출고
  mRetQty   Decimal @db.Decimal(18, 2) // BD 반품
  mDeadCtr  Decimal @db.Decimal(18, 2) // AC 센터체화금액
  mDeadSto  Decimal @db.Decimal(18, 2) // AI 지점체화금액

  @@index([snapshotId, gender, newcarry, season, item])
  @@map("fact_kanban")
}

// ── 분류 마스터 ───────────────────────────────────────────────────────────────
model DimClass {
  id        String @id @default(cuid())
  itemRaw   String // D (원라벨)
  item      String // 조합 → item
  genderRaw String // C
  gender    String // 조합2 → gender

  @@index([itemRaw])
  @@index([genderRaw])
  @@map("dim_class")
}

// ── 입력면: 비고·조치·목표·전년·물류비 (수기) ─────────────────────────────────
model Annotation {
  id          String     @id @default(cuid())
  kind        AnnoKind
  periodType  PeriodType
  periodStart DateTime   @db.Date // 귀속 기간(스냅샷과 분리 — 이력 무관 보존)
  gender      String? // 4키 노드(전사 비고면 NULL)
  newcarry    String?
  season      String?
  item        String?
  metricCode  String? // TARGET/PRIOR_YEAR/LOGI_COST 시 지표코드
  numValue    Decimal?   @db.Decimal(18, 2)
  textValue   String? // REMARK/ACTION 본문
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([kind, periodType, periodStart])
  @@index([gender, newcarry, season, item])
  @@map("annotations")
}

// ── 인증·RBAC ─────────────────────────────────────────────────────────────────
model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  emailVerified DateTime?
  image         String?
  role          Role            @default(VIEWER) // 가입=조회 기본
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  perms         TabPermission[]
  snapshots     Snapshot[]
  annotations   Annotation[]
  // Auth.js 관계
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model TabPermission {
  id     String    @id @default(cuid())
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tab    String // "logistics" | "store" | "product" | "input" | "admin"
  level  PermLevel

  @@unique([userId, tab])
  @@map("tab_permissions")
}

// ── OTP(이메일 6자리 일회용 코드) ──────────────────────────────────────────────
// 가입/로그인: @eland.co.kr 메일로 6자리 OTP 발송 → 수신자 인증. 코드는 해시로만 저장.
// 근거: 작업지시(OTP·해시저장·~10분 만료·시도제한) · 아키텍처 §4-1 인증 흐름.
model OtpToken {
  id         String    @id @default(cuid())
  email      String // 정규화(소문자·트림)된 수신 이메일
  codeHash   String // HMAC-SHA256(salt+code, AUTH_SECRET) — 평문 미보관
  salt       String // 레코드별 솔트
  expiresAt  DateTime // 발급 + ~10분
  attempts   Int       @default(0) // 검증 시도 횟수(한도 초과 시 무효)
  consumedAt DateTime? // 검증 성공으로 소비된 시각(1회용)
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([email, consumedAt])
  @@map("otp_tokens")
}

// ── 감사·ETL 로그 ─────────────────────────────────────────────────────────────
model IngestLog {
  id         String       @id @default(cuid())
  snapshotId String
  snapshot   Snapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  phase      IngestPhase
  result     IngestResult
  detail     Json?
  at         DateTime     @default(now())

  @@index([snapshotId, at])
  @@map("ingest_logs")
}

// ── 매장② 팩트 (snapshot × 점포, 매장 칸반 35열 + 기준마스터 + (−)재고) ──────────
// 근거: 02_파일분석/엔진_transform_spec_매장.md · store-engine-realfile.test(엑셀 100% 검증).
// SKU grain 이 아닌 점포 grain(31점). 데이터열=Decimal NOT NULL DEFAULT 0, 파생/마스터=nullable.
// 채널·지점명은 RAW 부재 마스터(칸반 B/C 원본) — 그대로 박제(복원 시 동일 트리).
model FactStore {
  id         String   @id @default(cuid())
  snapshotId String
  snapshot   Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  storeCode  String // A 점포코드(VLOOKUP 조인키 · 마스킹 대상)
  channel    String // B 구분(직영/중간관리/기타)
  storeName  String // C 지점명

  // 픽스블록(H~V) 데이터열
  mInQtyFix     Decimal @default(0) @db.Decimal(18, 2) // H 입고량(픽스)
  mInAmtFix     Decimal @default(0) @db.Decimal(18, 2) // I 입고액(픽스)
  mRetQtyFix    Decimal @default(0) @db.Decimal(18, 2) // J 반품량(픽스)
  mRetAmtFix    Decimal @default(0) @db.Decimal(18, 2) // K 반품액(픽스)
  mSaleQtyFix   Decimal @default(0) @db.Decimal(18, 2) // L 판매량(픽스)
  mSaleAmtFix   Decimal @default(0) @db.Decimal(18, 2) // M 판매액(픽스)
  mCogsFix      Decimal @default(0) @db.Decimal(18, 2) // N 매출원가(픽스)
  mSummerInvQty Decimal @default(0) @db.Decimal(18, 2) // P 여름/공통 재고량
  mSummerInvAmt Decimal @default(0) @db.Decimal(18, 2) // Q 여름/공통 재고액
  mInvQtyFix    Decimal @default(0) @db.Decimal(18, 2) // R 재고량(픽스)
  mInvAmtFix    Decimal @default(0) @db.Decimal(18, 2) // S 재고액(픽스)
  mOpenQtyFix   Decimal @default(0) @db.Decimal(18, 2) // T 기초재고량(픽스)
  mOpenAmtFix   Decimal @default(0) @db.Decimal(18, 2) // U 기초재고액(픽스)

  // 전체블록(W~AI) 데이터열
  mInQtyAll   Decimal @default(0) @db.Decimal(18, 2) // W 입고량(전체)
  mInAmtAll   Decimal @default(0) @db.Decimal(18, 2) // X 입고액(전체)
  mRetQtyAll  Decimal @default(0) @db.Decimal(18, 2) // Y 반품량(전체)
  mRetAmtAll  Decimal @default(0) @db.Decimal(18, 2) // Z 반품액(전체)
  mSaleQtyAll Decimal @default(0) @db.Decimal(18, 2) // AA 판매량(전체)
  mSaleAmtAll Decimal @default(0) @db.Decimal(18, 2) // AB 판매액(전체)
  mCogsAll    Decimal @default(0) @db.Decimal(18, 2) // AC 매출원가(전체)
  mInvQtyAll  Decimal @default(0) @db.Decimal(18, 2) // AE 기말재고량(전체)
  mInvAmtAll  Decimal @default(0) @db.Decimal(18, 2) // AF 기말재고액(전체)
  mOpenQtyAll Decimal @default(0) @db.Decimal(18, 2) // AG 기초재고량(전체)
  mOpenAmtAll Decimal @default(0) @db.Decimal(18, 2) // AH 기초재고액(전체)

  // 점포 기준 마스터(대시 H~K — 큐레이션 입력, nullable) + (−)재고(수불오차)
  areaPyeong     Decimal? @db.Decimal(18, 2) // H 운영평수
  baseInvQty     Decimal? @db.Decimal(18, 2) // I 기준재고량
  baseDisplayQty Decimal? @db.Decimal(18, 2) // J 기준진열량
  baseRunQty     Decimal? @db.Decimal(18, 2) // K 기준주판량
  isCard         Boolean  @default(false) // 대시보드 카드 노출 점포(큐레이션)
  mNegQty        Decimal? @db.Decimal(18, 2) // V (−)재고 수량(수불오차)
  mNegAmt        Decimal? @db.Decimal(18, 2) // W (−)재고 금액(수불오차)

  // ⚠️ 레거시(init 스키마 자리만) — 매장 엔진 미사용. 삭제 금지(헌장)·DEFAULT 0 보존.
  gender   String?
  item     String?
  mStoQty  Decimal @default(0) @db.Decimal(18, 2)
  mStoAmt  Decimal @default(0) @db.Decimal(18, 2)
  mDeadSto Decimal @default(0) @db.Decimal(18, 2)

  @@index([snapshotId, storeCode])
  @@index([snapshotId, channel])
  @@map("fact_store")
}

// ── 상품③ 팩트 (snapshot × 브랜드(구매그룹코드) × 시즌, 자동 6 데이터필드) ──────────
// 근거: 02_파일분석/상품SCM_뷰_스펙.md(§2 필드출처·§3 grain=구매그룹 F×시즌) ·
//        product-engine-realfile.test(아이템 엔진 전체합과 측정식 동치 검증).
// grain = 브랜드코드(구매그룹 F) × 시즌. 자동 6 데이터필드 = NOT NULL DEFAULT 0(파생은 복원 시 재계산).
// ⚠️ 자동불가(일자·리드타임 8필드)·수기(정보정확도·P별적합도·비고 3필드)는 본 테이블 밖
//    (일자=원천부재 / 수기=Annotation 모델). 가짜값 적재 금지.
// ⚠️ 레거시 컬럼(skuKey·gender·item·mSalesCum·mInCum·mOutCum)은 init 스키마 자리 — 보존(헌장 삭제금지).
model FactProductCum {
  id         String   @id @default(cuid())
  snapshotId String
  snapshot   Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  // ── 상품 grain(브랜드코드 × 시즌) ──
  brandCode String  @default("") // 구매그룹(Now:상품) F — 브랜드 조인키(마스킹 대상)
  season    String? // 시즌(봄/여름/가을/겨울/공통). 브랜드 소계·전체행은 NULL/""

  // ── 자동 6 데이터필드(SUMIFS 동치 — 아이템 엔진과 측정식 동일) ──
  mInQty   Decimal @default(0) @db.Decimal(18, 2) // 입고량 ← 센터입출고 I(벤더입고량)
  mInvQty  Decimal @default(0) @db.Decimal(18, 2) // 재고량 ← 물류재고 H(재고량)
  mOutQty  Decimal @default(0) @db.Decimal(18, 2) // 누적출고량 ← 센터입출고 M(점간출고량)
  mSaleQty Decimal @default(0) @db.Decimal(18, 2) // 누적판매량 ← 매출상세 J(판매수량)
  mSalesAmt Decimal @default(0) @db.Decimal(18, 2) // 실매출액 ← 매출상세 H (매총율 분모)
  mCogs    Decimal @default(0) @db.Decimal(18, 2) // 총매출원가 ← 매출상세 I (매총율 분자)

  // ── 레거시(init 스키마 자리 — 상품 엔진 미사용. 삭제금지·하위호환). ──
  skuKey    String  @default("")
  gender    String?
  item      String?
  mSalesCum Decimal @default(0) @db.Decimal(18, 2)
  mInCum    Decimal @default(0) @db.Decimal(18, 2)
  mOutCum   Decimal @default(0) @db.Decimal(18, 2)

  @@index([snapshotId, brandCode])
  @@index([snapshotId, skuKey])
  @@map("fact_product_cum")
}

// ── Auth.js 표준 모델 (PrismaAdapter) ─────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
