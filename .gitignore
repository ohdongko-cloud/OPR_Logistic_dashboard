# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — 실제 시크릿은 절대 커밋 금지. 단 .env.example 은 커밋(샘플).
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 실데이터 — 원본 엑셀/실적 파일은 절대 커밋 금지(로컬·마스킹 보안 규칙).
# (서버는 OPR_DATA_DIR 의 외부 경로에서 런타임 read 만 한다.)
*.xlsx
*.xlsm
*.xls
/data/

# PPTX: 원본(실데이터/실명 포함)은 커밋 금지. 마스킹 템플릿(assets/ppt-template.pptx)만 커밋.
*.pptx
!assets/ppt-template.pptx
# 마스킹 이름 denylist(실명 목록) — 로컬 빌드 전용, 커밋 금지.
scripts/.mask-names.local.txt
