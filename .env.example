# ==============================================================================
# OPR 물류 실적 대시보드 — 환경변수 샘플
# 실제 값은 .env.local 또는 Vercel envvar 로 주입. 이 파일엔 절대 시크릿 금지.
# ==============================================================================

# ------------------------------------------------------------------------------
# Neon Postgres
#   DATABASE_URL          = Pooled (Neon "Connection pooling" ON, hostname 에 '-pooler')
#                            → 앱 런타임(서버리스)에서 사용 (driver adapter)
#   DATABASE_URL_UNPOOLED = Direct (토글 OFF) → prisma migrate 에서 사용
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ------------------------------------------------------------------------------
# Auth.js (NextAuth v5)
#   AUTH_SECRET = 세션 암호화 키. 생성: npx auth secret  (또는 openssl rand -hex 32)
# ------------------------------------------------------------------------------
AUTH_SECRET="generate-with-npx-auth-secret"

# ------------------------------------------------------------------------------
# 로그인 도메인 제한 (RBAC 게이트)
#   ALLOWED_EMAIL_DOMAIN = 허용 도메인. 콤마로 여러 개. 예: "eland.co.kr"
#   ALLOWED_EMAILS       = 도메인 밖 예외 계정(정확매칭, 콤마구분). 선택.
#   ※ 셋 다 비면 "모두 차단"(안전한 기본값) — 최소 하나는 설정해야 로그인 가능.
# ------------------------------------------------------------------------------
ALLOWED_EMAIL_DOMAIN="eland.co.kr"
ALLOWED_EMAILS=""

# 마스터 관리자 1명 (RBAC). 하드코딩 금지 — 반드시 env. 항상 허용·강등 불가.
MASTER_ADMIN_EMAIL="oh_dongha01@eland.co.kr"

# ------------------------------------------------------------------------------
# 인증 메일 시스템 — 이메일 OTP (Google SMTP, nodemailer)
#   사내 @eland.co.kr 이메일 입력 → 6자리 OTP 발송 → 입력 시 인증(수신자 인증).
#
#   [A] Gmail 계정 + 앱비밀번호 (권장):
#       SMTP_USER = 발신 Gmail 주소 (예: opr.bot@gmail.com)
#       SMTP_PASS = Google "앱 비밀번호" 16자리 (2단계인증 후 발급 — 일반 비번 아님)
#   [B] 또는 단일 URL 한 줄:
#       EMAIL_SERVER = smtp://user%40gmail.com:app-password@smtp.gmail.com:587
#
#   EMAIL_FROM = 발신자 표기 (예: "OPR 물류 대시보드 <opr.bot@gmail.com>"). 선택.
#
#   ⚠️ dev 폴백: SMTP 미설정 시 개발환경(NODE_ENV!=production)에서는 OTP 를
#      서버 콘솔 로그로 출력(테스트용). production 에서는 절대 노출되지 않음(발송 실패).
# ------------------------------------------------------------------------------
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="OPR 물류 대시보드 <no-reply@example.com>"
# EMAIL_SERVER=""
